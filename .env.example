# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_BUCKET_NAME=viewora-tours
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
MEDIA_DOMAIN=https://media.viewora.software

# Paystack
PAYSTACK_SECRET_KEY=sk_live_your-key

# Redis (BullMQ job queue + auth/billing cache)
REDIS_URL=redis://default:password@localhost:6379

# App
PORT=3001
NODE_ENV=production
# URL of the dashboard app — used for Paystack payment callback redirect
APP_URL=https://app.viewora.software
CORS_ORIGIN=https://viewora.software,https://app.viewora.software,https://viewora.vercel.app

# Security
# Random secret shared between the API server and the tile worker
WORKER_SECRET=generate-a-random-secret-here
# Key required to call the /maintenance/sync-limits endpoint
MAINTENANCE_KEY=generate-a-random-key-here
# Token required to scrape the /metrics endpoint (leave unset to disable auth)
METRICS_TOKEN=

# Email (Resend)
RESEND_API_KEY=re_your-api-key

# Sentry (optional — leave blank to disable error tracking)
SENTRY_DSN=
